{
    "name": "iquety/application",
    "type": "tool",
    "description": "Libraries to create a decoupled application",
    "keywords": ["framework", "application", "mvc", "application controller"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.10",
        "iquety/console": "@stable",
        "iquety/http": "@stable",
        "iquety/injection": "@stable",
        "iquety/pubsub": "@stable",
        "iquety/routing": "@stable",
        "iquety/shield": "@stable",
        "laminas/laminas-diactoros": "^3.8",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0",
        "twig/twig": "^3.14",
        "filp/whoops": "^2.18"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "codacy/coverage": "dev-master",
        "iquety/docmap": "*",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.8",
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "Iquety\\Application\\": "src/",
            "Modules\\": "tests/project/Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts" : {
        "test": [
            "vendor/bin/phpunit --testdox"
        ],
        "docmap" : [
            "rm -Rf docs/pt-br/*",
            "vendor/bin/docmap -s docs-src/pt-br -d docs/pt-br -r leiame.md -l pt-br",
            "rm -Rf docs/en/*",
            "vendor/bin/docmap -s docs-src/en -d docs/en"
        ],
        "coverage": "vendor/bin/phpunit --coverage-html coverage",
        "mess": [
            "phpmd ./src ansi cleancode,codesize,unusedcode,naming,design,controversial",
            "phpmd ./tests ansi cleancode,codesize,unusedcode,naming,design,controversial"
        ],
        "stan": [
            "phpstan analyse --level=8 src",
            "phpstan analyse --level=8 tests"
        ],
        "psr-check": [
            "php-cs-fixer check --diff -v"
        ],

        "psr-fix": [
            "php-cs-fixer fix -v"
        ],
        "analyse": [
            "@psr-check",
            "@mess",
            "@stan"
        ]
    }
}
